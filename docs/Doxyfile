# Doxyfile — KernelSocket project
# Generated for Doxygen 1.9+
#
# Usage:
#   cd docs/
#   doxygen Doxyfile
#   # then open html/index.html

# ---------------------------------------------------------------------------
# Project metadata
# ---------------------------------------------------------------------------

PROJECT_NAME           = "KernelSocket"
PROJECT_NUMBER         = 0.1.0
PROJECT_BRIEF          = "Crossplatform kernel-mode TCP/UDP networking API"

# Optional: path to a 200x55px logo (PNG/JPG)
# PROJECT_LOGO         = logo.png

OUTPUT_DIRECTORY       = .

# ---------------------------------------------------------------------------
# Input sources
# ---------------------------------------------------------------------------

INPUT                  = ../include \
                         ../windows \
                         ../linux \
						 ../test \
						 ../README.md
						 
# Also scan subdirectories
RECURSIVE              = YES

# Only parse these extensions
FILE_PATTERNS          = *.h *.c *.cpp

# Exclude build artefacts and third-party dirs
EXCLUDE_PATTERNS       = */build/* \
                         */.git/*

# ---------------------------------------------------------------------------
# Extraction settings
# ---------------------------------------------------------------------------

# Extract everything, even undocumented symbols
EXTRACT_ALL            = NO

# Do extract static functions/variables
EXTRACT_STATIC         = YES

# Extract private struct members (useful for showing internals)
EXTRACT_PRIVATE        = NO

# Show brief description on the same line as the symbol
INLINE_INHERITED_MEMB  = YES

# Treat a line starting with /// as a brief comment
JAVADOC_AUTOBRIEF      = NO
QT_AUTOBRIEF           = NO

# ---------------------------------------------------------------------------
# Build options
# ---------------------------------------------------------------------------

OPTIMIZE_OUTPUT_FOR_C  = YES

# Macro expansion — define platform guards so both Win and Linux sections parse
ENABLE_PREPROCESSING   = YES
MACRO_EXPANSION        = YES
PREDEFINED             = __linux__=1 \
                         _WIN32=1 \
                         __cplusplus

# ---------------------------------------------------------------------------
# Warnings
# ---------------------------------------------------------------------------

QUIET                  = NO
WARNINGS               = YES
WARN_IF_UNDOCUMENTED   = YES
WARN_IF_DOC_ERROR      = YES
WARN_NO_PARAMDOC       = YES

# ---------------------------------------------------------------------------
# HTML output
# ---------------------------------------------------------------------------

GENERATE_HTML          = YES
HTML_OUTPUT            = html
HTML_FILE_EXTENSION    = .html

# Enable interactive tree navigation
GENERATE_TREEVIEW      = YES
TREEVIEW_WIDTH         = 250

# Sidebar-Only Theme
DISABLE_INDEX          = NO
FULL_SIDEBAR           = NO
HTML_HEADER            = header.html
HTML_EXTRA_FILES       = doxygen-awesome-css/doxygen-awesome-darkmode-toggle.js
HTML_EXTRA_STYLESHEET  = doxygen-awesome-css/doxygen-awesome.css \
                         doxygen-awesome-css/doxygen-awesome-sidebar-only.css \
						 doxygen-awesome-css/doxygen-awesome-sidebar-only-darkmode-toggle.css
HTML_COLORSTYLE        = DARK

# Syntax highlighting in code snippets
SOURCE_BROWSER         = YES
INLINE_SOURCES         = NO
REFERENCED_BY_RELATION = YES
REFERENCES_RELATION    = YES

# Better search
SEARCHENGINE           = YES

# ---------------------------------------------------------------------------
# LaTeX / PDF  (disabled by default — uncomment to enable)
# ---------------------------------------------------------------------------

GENERATE_LATEX         = NO
# LATEX_OUTPUT         = latex
# PDF_HYPERLINKS       = YES

# ---------------------------------------------------------------------------
# Graphs (requires Graphviz / dot)
# To install: sudo apt install graphviz  |  choco install graphviz
# ---------------------------------------------------------------------------

HAVE_DOT               = YES
DOT_NUM_THREADS        = 2

# Call/caller graphs for functions
CALL_GRAPH             = YES
CALLER_GRAPH           = YES

# Collaboration / include dependency graphs
COLLABORATION_GRAPH    = YES
INCLUDE_GRAPH          = YES
INCLUDED_BY_GRAPH      = YES

# Keep graph images inside the html output folder
DOT_PATH               = C:\Program Files\Graphviz\bin
DOT_GRAPH_MAX_NODES    = 50
MAX_DOT_GRAPH_DEPTH    = 3
DOT_IMAGE_FORMAT       = svg
INTERACTIVE_SVG        = YES

# ---------------------------------------------------------------------------
# Markdown support
# ---------------------------------------------------------------------------

MARKDOWN_SUPPORT       = YES

# Treat the project README as the main page
USE_MDFILE_AS_MAINPAGE = ../README.md
